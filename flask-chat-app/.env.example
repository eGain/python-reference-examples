EGAIN_CLIENT_ID=your_client_id_here
EGAIN_AUTH_URL=
EGAIN_TOKEN_URL=
EGAIN_PORTAL_ID=PZ-9999
EGAIN_LANGUAGE=en-US
# API domain for egain. Default is https://api.aidev.egain.cloud, but can be overridden.
EGAIN_API_DOMAIN=https://api.ai.egain.cloud
# Required for stable sessions. If unset, a new key is generated each run and existing sessions are invalidated.
APP_SECRET_KEY=change_this_to_a_random_secret_key

# Chat: minimum relevance score for search results (0.0–1.0). Only results above this are used.
MIN_RELEVANCE_SCORE=0.3

# LLM: one of openai, anthropic, gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
